# Anthropic
ANTHROPIC_API_KEY=

# Target environment — point at prod or local dev
BASE_URL=https://taxbros1.webtax.com
MAIN_URL=https://webtax.com

# Logto (for cleanup — same values as webtax-api .env)
LOGTO_ENDPOINT=https://auth.webtax.com
LOGTO_APP_ID=
LOGTO_APP_SECRET=
# OR set a pre-obtained management API token directly:
LOGTO_M2M_TOKEN=

# Webtax platform admin (for cleanup via API)
WEBTAX_API_URL=https://webtax.com
PLATFORM_ADMIN_TOKEN=

# Linear (for bug reporting)
LINEAR_API_KEY=
LINEAR_TEAM_ID=c98ad0e5-5ce0-46dc-a4aa-917ac534268c
LINEAR_BUG_LABEL_ID=

# Agent identity — all created subdomains/emails get this prefix
AGENT_PREFIX=agent
AGENT_EMAIL_DOMAIN=webtax-agent.test

# fast | normal | slow  (scales delays between agent actions)
SIMULATION_SPEED=normal

# LLM model for agents (haiku = cheaper, sonnet = smarter)
AGENT_MODEL=claude-haiku-4-5-20251001
